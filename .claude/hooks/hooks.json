{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude.common/hooks/scripts/block-no-verify.js",
            "description": "Block git --no-verify flag to enforce pre-commit hooks",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude.common/hooks/scripts/cost-tracker.js",
            "description": "Track token usage and cost metrics per session",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
